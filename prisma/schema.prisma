generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String              @id @default(uuid())
  email                 String              @unique
  passwordHash          String
  firstName             String
  lastName              String
  role                  UserRole            @default(JOB_SEEKER)
  avatarUrl             String?
  phone                 String?
  telegramId            String?             @unique
  isActive              Boolean             @default(true)
  emailVerified         Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  bio                   String?
  defaultResumeUrl      String?
  githubUrl             String?
  headline              String?
  linkedinUrl           String?
  location              String?
  portfolioUrl          String?
  skills                String[]            @default([])
  applications          Application[]
  bids                  Bid[]
  candidateScores       CandidateScore[]
  chatParticipants      ChatParticipant[]
  company               Company?
  contractsAsClient     Contract[]          @relation("ContractClient")
  contractsAsFreelancer Contract[]          @relation("ContractFreelancer")
  freelanceJobs         FreelanceJob[]
  wallet                FreelancerWallet?
  employerWallet        EmployerWallet?
  messages              Message[]
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  verificationTokens    VerificationToken[]
  savedJobs             SavedJob[]
  cvDraft               CvDraft?
  clientFeedback        Json?
  skillVerified         Boolean             @default(false)
  referralsGiven        Referral[]          @relation("ReferralReferrer")
  referralsReceived     Referral[]          @relation("ReferralReferred")
  jobAlerts             JobAlert[]
  payments              Payment[]

  @@map("users")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@map("saved_jobs")
}

model CvDraft {
  id        String   @id @default(uuid())
  userId    String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cv_drafts")
}

model ContactMessage {
  id        String               @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@map("contact_messages")
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model Company {
  id            String   @id @default(uuid())
  name          String
  description   String?
  logoUrl       String?
  website       String?
  industry      String?
  size          String?
  verified      Boolean  @default(false)
  userId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  benefits      String[] @default([])
  coverImageUrl String?
  facebookUrl   String?
  foundedYear   Int?
  linkedinUrl   String?
  location      String?
  twitterUrl    String?
  user          User     @relation(fields: [userId], references: [id])
  jobs          Job[]

  @@map("companies")
}

model JobCategory {
  id    String  @id @default(uuid())
  slug  String  @unique
  label String
  icon  String?
  jobs  Job[]

  @@map("job_categories")
}

model Job {
  id                String        @id @default(uuid())
  title             String
  description       String
  requirements      String?
  location          String
  type              JobType
  categoryId        String
  salaryMin         Int?
  salaryMax         Int?
  currency          String        @default("ETB")
  deadline          DateTime?
  status            JobStatus     @default(DRAFT)
  featured          Boolean       @default(false)
  companyId         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  applyEmail        String?
  applyType         String?
  applyUrl          String?
  companyLogo       String?
  companyName       String?
  contactPhone      String?
  experienceLevel   String?
  expiryDate        DateTime?
  filled            Boolean       @default(false)
  gender            String?
  jobSite           String?
  qualification     String?
  salaryType        String?
  tags              String[]      @default([])
  urgent            Boolean       @default(false)
  vacancies         Int?          @default(1)
  yearsOfExperience String?
  applications      Application[]
  questions         JobQuestion[]
  savedBy           SavedJob[]
  category          JobCategory   @relation(fields: [categoryId], references: [id])
  company           Company       @relation(fields: [companyId], references: [id])

  @@index([title, location])
  @@index([status, featured])
  @@index([companyId, status])
  @@index([categoryId, status])
  @@index([expiryDate])
  @@map("jobs")
}

model JobQuestion {
  id        String   @id @default(uuid())
  jobId     String
  question  String
  type      String   @default("TEXT")
  options   String[] @default([])
  required  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_questions")
}

model Application {
  id               String            @id @default(uuid())
  jobId            String
  userId           String
  coverLetter      String?
  resumeUrl        String?
  status           ApplicationStatus @default(SUBMITTED)
  interviewSlot    DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expectedSalary   Int?
  portfolioUrl     String?
  screeningAnswers Json?
  job              Job               @relation(fields: [jobId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  score            CandidateScore?

  @@unique([jobId, userId])
  @@index([userId, status])
  @@index([jobId, status])
  @@map("applications")
}

model CandidateScore {
  id              String      @id @default(uuid())
  applicationId   String      @unique
  userId          String
  overallScore    Float
  skillScore      Float
  experienceScore Float
  cultureFitScore Float?
  reasoning       String?
  rawAiResponse   Json?
  modelUsed       String      @default("gpt-4o-mini")
  scoredAt        DateTime    @default(now())
  application     Application @relation(fields: [applicationId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("candidate_scores")
}

model FreelanceCategory {
  id    String         @id @default(uuid())
  slug  String         @unique
  label String
  icon  String?
  jobs  FreelanceJob[]

  @@map("freelance_categories")
}

model FreelanceJob {
  id                 String             @id @default(uuid())
  title              String
  description        String
  categoryId         String
  clientId           String
  budgetMin          Int
  budgetMax          Int
  currency           String             @default("ETB")
  pricingType        String             @default("FIXED")
  deadlineDays       Int
  skills             String[]
  status             FreelanceJobStatus @default(DRAFT)
  featured           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  attachments        String[]           @default([])
  experienceLevel    String?
  locationPreference String?
  bids               Bid[]
  contract           Contract?
  escrowTx           EscrowTransaction?
  category           FreelanceCategory  @relation(fields: [categoryId], references: [id])
  client             User               @relation(fields: [clientId], references: [id])

  @@map("freelance_jobs")
}

model Bid {
  id             String       @id @default(uuid())
  freelanceJobId String
  freelancerId   String
  amount         Int
  timelineDays   Int
  coverLetter    String
  status         BidStatus    @default(PENDING)
  qualityScore   Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  freelanceJob   FreelanceJob @relation(fields: [freelanceJobId], references: [id])
  freelancer     User         @relation(fields: [freelancerId], references: [id])

  @@unique([freelanceJobId, freelancerId])
  @@map("bids")
}

model Contract {
  id             String         @id @default(uuid())
  freelanceJobId String         @unique
  clientId       String
  freelancerId   String
  agreedAmount   Int
  currency       String         @default("ETB")
  status         ContractStatus @default(ACTIVE)
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  updatedAt      DateTime       @updatedAt
  client         User           @relation("ContractClient", fields: [clientId], references: [id])
  freelanceJob   FreelanceJob   @relation(fields: [freelanceJobId], references: [id])
  freelancer     User           @relation("ContractFreelancer", fields: [freelancerId], references: [id])
  dispute        Dispute?
  milestones     Milestone[]

  @@map("contracts")
}

model Milestone {
  id           String          @id @default(uuid())
  contractId   String
  title        String
  description  String?
  amount       Int
  deadline     DateTime
  status       MilestoneStatus @default(PENDING)
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deliverables Deliverable[]
  contract     Contract        @relation(fields: [contractId], references: [id])

  @@map("milestones")
}

model Deliverable {
  id          String    @id @default(uuid())
  milestoneId String
  fileUrl     String?
  notes       String?
  submittedAt DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@map("deliverables")
}

model EscrowTransaction {
  id              String       @id @default(uuid())
  freelanceJobId  String       @unique
  grossAmount         Int
  platformFee         Int
  netAmount           Int
  walletAppliedAmount Int          @default(0)
  currency            String       @default("ETB")
  status          EscrowStatus @default(PENDING)
  gatewayRef      String?
  gatewayResponse Json?
  fundedAt        DateTime?
  releasedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  freelanceJob    FreelanceJob @relation(fields: [freelanceJobId], references: [id])

  @@map("escrow_transactions")
}

model FreelancerWallet {
  id               String              @id @default(uuid())
  userId           String              @unique
  pendingBalance   Int                 @default(0)
  availableBalance Int                 @default(0)
  currency         String              @default("ETB")
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id])
  transactions     WalletTransaction[]

  @@map("freelancer_wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  type        WalletTransactionType
  amount      Int
  note        String?
  milestoneId String?
  createdAt   DateTime              @default(now())
  wallet      FreelancerWallet      @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model EmployerWallet {
  id               String                      @id @default(uuid())
  userId           String                      @unique
  balance          Int                         @default(0)
  lockedBalance    Int                         @default(0)
  currency         String                      @default("ETB")
  updatedAt        DateTime                    @updatedAt
  user             User                        @relation(fields: [userId], references: [id])
  transactions     EmployerWalletTransaction[]

  @@map("employer_wallets")
}

model EmployerWalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  type        WalletTransactionType
  amount      Int
  note        String?
  escrowId    String?
  createdAt   DateTime              @default(now())
  wallet      EmployerWallet        @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("employer_wallet_transactions")
}

model Dispute {
  id           String    @id @default(uuid())
  contractId   String    @unique
  raisedById   String
  reason       String
  evidenceUrls String[]
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contract     Contract  @relation(fields: [contractId], references: [id])

  @@map("disputes")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  type      String
  title     String
  body      String
  read      Boolean             @default(false)
  metadata  Json?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model EventLog {
  id          String   @id @default(uuid())
  eventType   String
  entityId    String
  entityType  String
  payload     Json
  processedBy String?
  createdAt   DateTime @default(now())

  @@index([eventType, entityId])
  @@map("events_log")
}

model ChatRoom {
  id           String            @id @default(uuid())
  contractId   String?           @unique
  jobId        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  messages     Message[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(uuid())
  roomId     String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  room       ChatRoom  @relation(fields: [roomId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("chat_participants")
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  content   String
  isSystem  Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([roomId, createdAt])
  @@map("messages")
}

enum UserRole {
  ADMIN
  EMPLOYER
  JOB_SEEKER
  FREELANCER
}

enum JobType {
  FULL_TIME
  PART_TIME
  REMOTE
  HYBRID
  CONTRACT
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  SUBMITTED
  SCREENING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFERED
  REJECTED
  WITHDRAWN
}

enum FreelanceJobStatus {
  DRAFT
  FUNDED
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

enum EscrowStatus {
  PENDING
  FUNDED
  IN_REVIEW
  RELEASED
  REFUNDED
  DISPUTED
}

enum WalletTransactionType {
  CREDIT_PENDING
  CREDIT_AVAILABLE
  DEBIT_WITHDRAWAL
  DEBIT_FEE
}

enum NotificationChannel {
  IN_APP
  TELEGRAM
  EMAIL
}

// ── Referrals ──────────────────────────────────────────────────────────────

model Referral {
  id           String         @id @default(uuid())
  referrerId   String
  referredId   String?
  code         String         @unique
  status       ReferralStatus @default(PENDING)
  /// Bonus amount in minor units (e.g. cents / santim)
  bonusAmount  Int            @default(0)
  /// ISO 4217 currency code (e.g. ETB, USD, EUR) — multi-currency support
  currency     String         @default("ETB")
  expiresAt    DateTime
  redeemedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  referrer     User           @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred     User?          @relation("ReferralReferred", fields: [referredId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([code])
  @@index([status, expiresAt])
  @@map("referrals")
}

// ── Job Alerts ─────────────────────────────────────────────────────────────

model JobAlert {
  id         String   @id @default(uuid())
  userId     String
  keywords   String[]
  location   String?
  jobType    JobType?
  /// Minimum salary in minor units — multi-currency support
  minSalary  Int?
  /// ISO 4217 currency code
  currency   String   @default("ETB")
  isActive   Boolean  @default(true)
  lastSentAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("job_alerts")
}

enum ReferralStatus {
  PENDING
  REDEEMED
  EXPIRED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// Global Payment Gateway (Task Global-Payments-001 & 002)
// ─────────────────────────────────────────────────────────────────────────────
//
// Stores every payment transaction (Stripe or PayPal) initiated via the
// Beleqet platform.
//
// GDPR notes:
//  - No raw PII stored here (no card numbers, email, name).
//  - userId is a UUID reference to the users table.
//  - metadata is sanitised before insert (PII keys stripped in services).
//
// Multi-currency: `currency` is ISO 4217. `amount` is in smallest unit
// (cents/fils/pence) for Stripe; stored as-is for PayPal (decimal × 100).
model Payment {
  id                 String          @id @default(uuid())
  /// UUID of the Beleqet user who initiated this payment
  userId             String
  /// Payment provider: STRIPE or PAYPAL
  provider           PaymentProvider
  /// Provider-side payment / order ID (pi_… for Stripe, alphanumeric for PayPal)
  providerPaymentId  String          @unique
  /// Amount in smallest currency unit (e.g. cents for USD)
  amount             Int
  /// ISO 4217 currency code (e.g. USD, EUR, ETB)
  currency           String          @default("USD")
  /// Current lifecycle status
  status             PaymentStatus   @default(PENDING)
  /// Human-readable description (stripped of PII before storage)
  description        String?
  /// Sanitised key-value metadata (no PII keys)
  metadata           Json?
  /// Timestamp when this payment was refunded (null if not refunded)
  refundedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Index for looking up all payments by a user (dashboard, history)
  @@index([userId, createdAt])
  /// Index for admin filtering by status + provider
  @@index([status, provider])
  /// Index for webhook event processing by providerPaymentId
  @@index([providerPaymentId])
  /// Index for currency-based reporting (multi-currency analytics)
  @@index([currency, status])

  @@map("payments")
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}
